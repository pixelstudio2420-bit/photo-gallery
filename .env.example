APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (PostgreSQL) ────────────────────────────────────────────
# This is the Postgres fork of the project. Switch DB_CONNECTION to
# `mysql` only if you've reverted the SQL dialect changes back to MySQL.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=jabphap
DB_USERNAME=postgres
DB_PASSWORD=
DB_CHARSET=utf8
DB_SSLMODE=prefer

# ── Read replicas (50k+ concurrent production) ──────────────────────
# Uncomment and set DB_READ_HOST to enable read/write split.
# Accepts comma-separated list for multiple replicas.
# DB_READ_HOST=10.0.1.10,10.0.1.11
# DB_READ_USERNAME=laravel_read
# DB_READ_PASSWORD=
# DB_READ_PORT=5432

# ── Session / Cache / Queue ─────────────────────────────────────────
# Production (1k+ concurrent users) → set all three to `redis`.
# Dev without redis → use `file` for cache+session, `database` for queue.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_DRIVER=redis  # enable in production
# SESSION_CONNECTION=default

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# QUEUE_CONNECTION=redis  # enable in production

CACHE_STORE=file
CACHE_PREFIX=pg_
# CACHE_STORE=redis  # enable in production
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# CloudFront CDN
AWS_CLOUDFRONT_DOMAIN=
AWS_CLOUDFRONT_DISTRIBUTION_ID=
AWS_CLOUDFRONT_KEY_PAIR_ID=

# ── CDN for static assets (50k+ concurrent production) ──────────────
CDN_BASE_URL=

# Google OAuth & Drive — managed in DB via /admin/settings.

# Facebook OAuth
FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

# LINE — managed in DB via /admin/settings/line and /admin/marketing/line.

# Payment Gateways — managed in DB via /admin/settings/payment-gateways.

# Analytics — managed in DB via /admin/settings/analytics.

# ── Security policy ─────────────────────────────────────────────────
ENFORCE_ADMIN_2FA=

# Allow Factory Reset in production. OFF by default.
ALLOW_FACTORY_RESET=false

# ── Sentry error tracking ───────────────────────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT="${APP_ENV}"
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# ── LLM / AI providers ─────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-5-haiku-20241022

# ── Inbound chat-channel webhooks ──────────────────────────────────
FACEBOOK_VERIFY_TOKEN=

LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

VITE_APP_NAME="${APP_NAME}"

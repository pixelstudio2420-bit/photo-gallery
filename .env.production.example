# ════════════════════════════════════════════════════════════════════════
# Photo Gallery — Production .env template
# ════════════════════════════════════════════════════════════════════════
# Copy to `.env` on the production server, fill in real values, then:
#   chmod 600 .env
#   php artisan config:cache
#   php artisan route:cache
#   php artisan view:cache
#   php artisan event:cache
# ════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# 1. APPLICATION
# ─────────────────────────────────────────────
APP_NAME="Photo Gallery"
APP_ENV=production
APP_KEY=                                  # ← run: php artisan key:generate
APP_DEBUG=false                           # MUST be false in production
APP_URL=https://yourdomain.com            # MUST be HTTPS + no trailing slash

APP_LOCALE=th
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=Asia/Bangkok

APP_MAINTENANCE_DRIVER=file

FORCE_HTTPS=true                          # ForceHttps middleware redirect
CSP_ENFORCE=false                         # set true after CSP audit passes

# ─────────────────────────────────────────────
# 2. LOGGING
# ─────────────────────────────────────────────
# Use `daily` channel in prod so log rotation works out of the box.
# Combined with logrotate (see docs/deployment/logrotate.conf) you get
# 14 days of logs, compressed after day 2.
LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                         # debug/info noisy in prod — keep warning+

# ─────────────────────────────────────────────
# 3. DATABASE
# ─────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=photo_gallery
DB_USERNAME=                              # DO NOT use root
DB_PASSWORD=                              # 20+ char random string
# Optional read replica (uncomment when you add one):
# DB_READ_HOST=read-replica.internal

BCRYPT_ROUNDS=12                          # prod: 12. Dev: 10.

# ─────────────────────────────────────────────
# 4. SESSION / CACHE / QUEUE — PRODUCTION STACK
# ─────────────────────────────────────────────
# Above ~500 concurrent users OR 2+ web servers, switch everything to redis.
# Below that, file+database is fine on a single machine.
SESSION_DRIVER=redis                      # redis | file | database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true                      # prod: true
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=redis                         # redis | file | database
CACHE_PREFIX=pg_

QUEUE_CONNECTION=redis                    # redis for speed, database for simplicity
BROADCAST_CONNECTION=log

FILESYSTEM_DISK=s3                        # s3 | r2 | public

# ─────────────────────────────────────────────
# 5. REDIS
# ─────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=                           # set in production!
REDIS_DB=0
REDIS_CACHE_DB=1

# ─────────────────────────────────────────────
# 6. MAIL (SMTP / Mailgun / SES)
# ─────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=                            # Gmail: App Password (16 chars, no spaces)
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────
# 7. OAuth  —  MANAGED IN DATABASE (NOT .ENV!)
# ─────────────────────────────────────────────
# As of v1.1, OAuth credentials live in `app_settings` table, not .env.
# Configure via /admin/settings/social-auth after first login.
#
# Facebook still supports .env fallback (for fresh installs):
FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

# ─────────────────────────────────────────────
# 8. AWS S3 (primary object storage)
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_URL=https://YOUR-BUCKET.s3.ap-southeast-1.amazonaws.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# Optional CloudFront (faster image delivery)
AWS_CLOUDFRONT_DOMAIN=
AWS_CLOUDFRONT_DISTRIBUTION_ID=
AWS_CLOUDFRONT_KEY_PAIR_ID=

# ─────────────────────────────────────────────
# 9. Cloudflare R2 (alternative to S3, no egress fees)
# ─────────────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_URL=

# ─────────────────────────────────────────────
# 10. PAYMENT GATEWAYS  —  MANAGED IN DATABASE
# ─────────────────────────────────────────────
# Stripe / Omise / PayPal / TrueMoney / 2C2P / LINE Pay / PromptPay keys
# are all managed via /admin/settings/payment-gateways.
#
# Exception — Stripe webhook secret should live here (webhooks can't
# boot the app for a DB lookup before signature verification):
STRIPE_WEBHOOK_SECRET=whsec_

# ─────────────────────────────────────────────
# 11. ASSETS / VITE
# ─────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────────────
# 12. MONITORING / OBSERVABILITY (optional but recommended)
# ─────────────────────────────────────────────
# Sentry / Bugsnag — install the package and fill in DSN
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# New Relic / Datadog via their PHP agents — configure via init.ini
